# ───────────────────────────────────────────────────────────────────────────
# goread environment variables
#
# NONE of these are required to run the app or pass the test suite.
# Out of the box (no env), goread serves the FULL ~90,000-book catalogue from
# gutenberg.org's own catalog feed, falling back to a bundled sample set if the
# feed is unreachable.
# ───────────────────────────────────────────────────────────────────────────

# ── Catalogue ───────────────────────────────────────────────────────────────
# Leave unset (or 0) to use the full live catalogue (pg_catalog.csv).
# Set to 1 to force the bundled offline/demo set (used by the test suite).
GOREAD_USE_FIXTURES=
# Optional override of the Gutenberg base used for the catalog feed + book files.
# GUTENBERG_BASE_URL=https://www.gutenberg.org

# ── Auth: Clerk (Google / Apple sign-in) ────────────────────────────────────
# Get from https://dashboard.clerk.com → create app → enable Google & Apple.
# In Clerk's DEV instance, Google & Apple work with Clerk's shared OAuth creds,
# so you do NOT need the $99/yr Apple Developer Program just to test.
# Without these, the app runs in guest mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Database: Neon Postgres ─────────────────────────────────────────────────
# Get from Vercel → Marketplace → Neon, or https://neon.tech
# Without this, persistence falls back to the browser (localStorage/IndexedDB).
DATABASE_URL=

# ── EPUB cache: Vercel Blob (optional) ──────────────────────────────────────
# Get from Vercel → Storage → Blob. Without it, EPUBs are proxied on the fly.
BLOB_READ_WRITE_TOKEN=
